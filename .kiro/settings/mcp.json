{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ],
      "disabled": true,
      "autoApprove": [
        "resolve-library-id",
        "query-docs"
      ]
    },
    "brouter": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/brouter",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "calculate_route",
        "search_location",
        "render_gpx_map",
        "render_elevation_profile"
      ]
    },
    "open-meteo": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/open-meteo",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "weather_forecast",
        "geocoding"
      ]
    },
    "vbb": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/vbb",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "search_stops",
        "get_departures",
        "get_journeys"
      ]
    },
    "overpass": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/overpass",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "search_pois_along_route"
      ]
    },
    "openrouteservice": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/ors",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "calculate_route",
        "geocode",
        "driving_time",
        "distance_matrix"
      ],
      "disabledTools": []
    },
    "wikivoyage": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/wikivoyage",
        "fastmcp",
        "run",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "search_destinations",
        "get_article",
        "get_section",
        "get_article_sections",
        "search_nearby"
      ]
    },
    "waymarkedtrails": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "mcp/waymarkedtrails",
        "fastmcp",
        "run",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "search_routes",
        "get_route_details",
        "search_routes_in_region",
        "get_route_segments"
      ]
    }
  }
}