{
  "mcpServers": {
    "brouter": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "brouter-mcp",
        "python",
        "server.py"
      ],
      "disabled": false,
      "autoApprove": [
        "calculate_route",
        "search_location",
        "render_gpx_map"
      ]
    },
    "weather": {
      "command": "npx",
      "args": [
        "-y",
        "open-meteo-mcp-server"
      ],
      "disabled": false,
      "autoApprove": [
        "weather_forecast",
        "geocoding"
      ]
    },
    "berlin-transport": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://berlin-transport.mcp-tools.app/sse"
      ],
      "disabled": false,
      "autoApprove": [
        "search_stops",
        "get_journeys"
      ]
    }
  }
}