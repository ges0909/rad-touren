{
  "enabled": true,
  "name": "GPX Round Trip Validation",
  "description": "Validates newly created cycling/hiking GPX files: checks trk/trkseg/trkpt format, verifies start ≈ end (round trip), and reports trackpoint count.",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "cycling/gpx/*.gpx",
      "hiking/gpx/*.gpx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new GPX file was created. Validate the following:\n1. Does the file use `<trk>/<trkseg>/<trkpt>` format (NOT `<rte>/<rtept>`)?\n2. Is the first trackpoint identical or very close to the last trackpoint (round trip)?\n3. How many trackpoints does the file contain?\nIf any issues are found, inform the user."
  }
}
